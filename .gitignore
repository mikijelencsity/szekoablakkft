# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# eredeti (feldolgozatlan) referenciaképek — csak a legyártott
# public/referenciak/ verzió kerül a repóba, az eredetik a gépen maradnak
/_kepek/**
!/_kepek/OLVASSEL.txt
!/_kepek/*/
!/_kepek/*/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
